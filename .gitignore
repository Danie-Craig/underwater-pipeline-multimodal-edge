# ─── Python ───────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/

# ─── Virtual environments ─────────────────────────────────────────────────
venv/
.venv/
env/

# ─── Data (never committed — pulled per machine; see README) ──────────────
# Datasets (downloaded / generated). Anchored to repo root with a leading
# slash so this does NOT also match the src/data/ source package.
/data/

# ─── Model artifacts (heavy / machine-specific — see §7, §11) ─────────────
# Trained weights, ONNX exports, and TensorRT engines are all regenerated,
# not version-controlled. TensorRT engines are GPU- + version-specific and
# MUST be built on the Jetson itself, so they never belong in git.
*.pt
*.pth
*.onnx
# Exception: the small ONNX exports ARE committed — they are the
# architecture-neutral bridge to the Jetson (engines are still built
# on-device from these, and are never committed).
!models/onnx/*.onnx
*.engine
*.plan
*.trt
models/trt_cache/

# ─── Ultralytics training output (heavy; key plots are copied to results/) ──
runs/

# ─── Results ──────────────────────────────────────────────────────────────
# Keep the small, portfolio-worthy artifacts (JSON tables, PNG plots) tracked.
# Large binaries stay out, EXCEPT the annotated demo videos, which are the
# headline qualitative result and small enough to ship.
*.mp4
*.avi
*.mov
!results/inference/*_demo.mp4

# ─── OS / editor cruft ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.log
